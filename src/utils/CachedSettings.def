    X(disableBackground, bool, "disableBackground")                     \
    X(disableNewRate, bool, "disableNewRate")                           \
    X(disableNewRateInLevel, bool, "disableNewRateInLevel")             \
    X(disableNameplate, bool, "disableNameplate")                       \
    X(disableNameplateInComment, bool, "disableNameplateInComment")     \
    X(disableRLReq, bool, "disableRLReq")                               \
    X(disableRLMenu, bool, "disableRLMenu")                             \
    X(disableMenuAnimation, bool, "disableMenuAnimation")               \
    X(disableRewardAnimation, bool, "disableRewardAnimation")           \
    X(disableParticles, bool, "disableParticles")                       \
    X(disableRLSearchLayer, bool, "disableRLSearchLayer")               \
    X(disableCommentGlow, bool, "disableCommentGlow")                   \
    X(disableCommentGlowNameplate, bool, "disableCommentGlowNameplate") \
